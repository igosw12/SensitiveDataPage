@page
@model SensitiveDataPage.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="main-dashboard">
    <div class="dashboard-header">
        <div class="dashboard-logo">
            <img class="logoImg" src="~/img/logo.png" />
        </div>
        <div class="dashboard-actions">
            <div class="app-controls">
                <button class="action-btn lang-btn" data-lang="en" onclick="applyLang('en')">EN</button>
                <button class="action-btn lang-btn" data-lang="pl" onclick="applyLang('pl')">PL</button>
                <label class="toggle-switch-wrap" title="Dark mode">
                    <span class="toggle-label">☀</span>
                    <label class="toggle-switch">
                        <input type="checkbox" id="darkModeToggle" onchange="toggleTheme()">
                        <span class="toggle-slider"></span>
                    </label>
                    <span class="toggle-label">☾</span>
                </label>
            </div>
            <div class="dropdown">
                <button class="action-btn dropbtn-styled">Hello @Model.Email</button>
                <div class="dropdown-content-styled">
                    <a class="dropdown-item-styled" onclick="openSettings()" data-i18n="dash.settings">Ustawienia konta ⚙</a>
                    <form method="post" asp-page-handler="Logout" style="margin:0;">
                        <button type="submit" class="action-btn logout-btn" data-i18n="dash.logout">Wyloguj ⏻</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="top-dashboard">
    <div class="tier-dashboard">
        <a class="tier1Data" onclick="loadTier(1, t('dash.tier1'))" data-i18n="dash.tier1">Dane poufne</a>
        <a class="tier2Data" onclick="loadTier(2, t('dash.tier2'))" data-i18n="dash.tier2">Dane wrażliwe</a>
        <a class="tier3Data" onclick="loadTier(3, t('dash.tier3'))" data-i18n="dash.tier3">Dane publiczne</a>
        <a class="tier4Data" onclick="loadTier(4, t('dash.tier4'))" data-i18n="dash.tier4">Niestandardowe dane</a>
    </div>
</div>

<div id="dashboardAlert" class="modal-alert" style="display:none;"></div>

<div id="settingsModal" class="modal">
    <div class="modal-content">
        <div class="modal-header-settings">
            <h2 class="settingsTitle" data-i18n="dash.settingsTitle">Ustawienia konta</h2>
            <span class="closeSettings" onclick="closeSettings()">&times;</span>
        </div>

        <div class="settings-2fa-row">
            <span data-i18n="dash.twoFactor">Weryfikacja dwuskładnikowa</span>
            <label class="toggle-switch">
                <input type="checkbox" id="twoFactorToggle" @(Model.TwoFactorEnabled ? "checked" : "") onchange="toggle2fa(this)">
                <span class="toggle-slider"></span>
            </label>
        </div>
        <div class="settings-2fa-row">
            <a class="settings-link" onclick="openChangePassword()" data-i18n="dash.changePass">Zmień hasło</a>
        </div>
        <div class="settings-2fa-row">
            <a class="deleteAccount" onclick="openDeleteConfirm()" data-i18n="dash.deleteAcc">Usuń konto</a>
        </div>
    </div>
</div>

<div id="changePasswordModal" class="modal">
    <div class="modal-content">
        <div class="modal-header-settings">
            <h2 class="settingsTitle" data-i18n="dash.changePass">Zmień hasło</h2>
            <span class="closeSettings" onclick="closeChangePassword()">&times;</span>
        </div>
        <div id="changePasswordAlert" class="modal-alert" style="display:none;"></div>
        <div class="mb-3">
            <label class="field-label" data-i18n="dash.oldPassword">Stare hasło</label>
            <input id="cp-old" class="form-control" type="password" placeholder="••••••••" data-i18n="dash.oldPassword" />
        </div>
        <div class="mb-3">
            <label class="field-label" data-i18n="dash.newPassword">Nowe hasło</label>
            <input id="cp-new" class="form-control" type="password" placeholder="••••••••" data-i18n="dash.newPassword"
                   pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$"
                   oninvalid="this.setCustomValidity(t('dash.passwordRule'))"
                   oninput="this.setCustomValidity(''); validateConfirm();" />
        </div>
        <div class="mb-3">
            <label class="field-label" data-i18n="dash.confirmPassword">Potwierdź nowe hasło</label>
            <input id="cp-confirm" class="form-control" type="password" placeholder="••••••••" data-i18n="dash.confirmPassword"
                   oninput="validateConfirm()" />
            <small id="cp-match-hint" class="text-danger" style="display:none;" data-i18n="dash.passwordMismatch">Hasła nie są identyczne</small>
        </div>
        <div style="display:flex; gap:0.8em; margin-top:1.2em;">
            <button class="action-btn" style="flex:1; background: #2a6496;" onclick="submitChangePassword()" data-i18n="dash.changePassBtn">Zmień hasło</button>
            <button class="action-btn" style="flex:1;" onclick="closeChangePassword()" data-i18n="dash.deleteConfirmNo">Anuluj</button>
        </div>
    </div>
</div>

<div id="deleteConfirmModal" class="modal">
    <div class="modal-content">
        <div class="modal-header-settings">
            <h2 class="settingsTitle" data-i18n="dash.deleteConfirmTitle">Usuń konto</h2>
            <span class="closeSettings" onclick="closeDeleteConfirm()">&times;</span>
        </div>
        <p data-i18n="dash.deleteConfirmMsg">Czy na pewno chcesz usunąć konto? Tej operacji nie można cofnąć.</p>
        <div style="display:flex; gap:0.8em; margin-top:1.2em;">
            <form method="post" asp-page-handler="DeleteAccount" style="flex:1; margin:0;">
                <button type="submit" class="action-btn logout-btn" style="width:100%;" data-i18n="dash.deleteConfirmYes">Tak, usuń konto</button>
            </form>
            <button class="action-btn" style="flex:1;" onclick="closeDeleteConfirm()" data-i18n="dash.deleteConfirmNo">Anuluj</button>
        </div>
    </div>
</div>

<div id="tier-panel" style="display:none;" class="tier-panel">
    <h4 id="tier-title"></h4>

    <div class="search-bar">
        <input id="search-input" class="form-control" placeholder="Search by name or category..." data-i18n="dash.searchPh" oninput="filterAndRender()" />
        <select id="search-category" class="form-control" onchange="filterAndRender()">
            <option value="" data-i18n="dash.allCategories">All categories</option>
            <option value="Account">Account</option>
            <option value="Address">Address</option>
            <option value="Card">Card</option>
            <option value="Phone">Phone</option>
            <option value="Documents">Documents</option>
            <option value="Others">Others</option>
        </select>
    </div>
    <form id="add-form" class="add-form">
        <div class="add-form-top">
            <input id="input-type" class="form-control" placeholder="Nazwa wpisu (np. Konto Gmail)" data-i18n="dash.entryName" required />
            <select id="input-category" class="form-control" required onchange="renderDynamicFields(this.value, 'dynamic-fields', null)">
                <option value="" data-i18n="dash.selectCategory">-- Wybierz kategorię --</option>
                <option value="Account">Account</option>
                <option value="Address">Address</option>
                <option value="Card">Card</option>
                <option value="Phone">Phone</option>
                <option value="Documents">Documents</option>
                <option value="Others">Others</option>
            </select>
        </div>
        <div id="dynamic-fields" class="dynamic-fields-grid"></div>
        <button type="button" class="submitBtn add-btn" data-i18n="dash.addBtn" onclick="submitAddForm(this)">Add</button>
    </form>

    <table class="table entries-table">
        <thead>
            <tr>
                <th class="columnName" data-sort="name" data-i18n="dash.colName">Nazwa</th>
                <th class="columnName" data-sort="category" data-i18n="dash.colCategory">Kategoria</th>
                <th class="columnName" data-sort="fields" data-i18n="dash.colFields">Pola</th>
                <th class="columnName" data-sort="added" data-i18n="dash.colAdded">Dodano</th>
                <th></th>
            </tr>
        </thead>
        <tbody id="entries-body"></tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
