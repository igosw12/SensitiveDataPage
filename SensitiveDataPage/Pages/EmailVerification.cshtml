@page
@model SensitiveDataPage.Pages.EmailVerificationModel
@{
    ViewData["Title"] = "Email Verification";
}

<div class="auth-page">
    <div class="auth-header">
        <div class="auth-logo">
            <img class="logoImg" src="~/img/logo.png" />
        </div>
        <div class="app-controls">
            <button class="action-btn lang-btn" data-lang="en" onclick="applyLang('en')">EN</button>
            <button class="action-btn lang-btn" data-lang="pl" onclick="applyLang('pl')">PL</button>
            <label class="toggle-switch-wrap" title="Dark mode">
                <span class="toggle-label">?</span>
                <label class="toggle-switch">
                    <input type="checkbox" id="darkModeToggle" onchange="toggleTheme()">
                    <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label">?</span>
            </label>
        </div>
    </div>

    <div class="auth-card">
        @if (Model.Success)
        {
            <div class="auth-card-icon success">?</div>
            <div class="auth-card-title">Email Verification</div>
            <div class="alert alert-success" role="alert">@Model.Message</div>
            <a asp-page="/Login" class="newAccountBtn">Sign in</a>
        }
        else
        {
            <div class="auth-card-icon danger">?</div>
            <div class="auth-card-title">Email Verification</div>
            <div class="alert alert-danger" role="alert">@Model.Message</div>
            <a asp-page="/Login" class="newAccountBtn">Return to login</a>
        }
    </div>
</div>