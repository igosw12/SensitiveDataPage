@page
@model SensitiveDataPage.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-page">
    <div class="auth-header">
        <div class="auth-logo">
            <img class="logoImg" src="~/img/logo.png" />
        </div>
        <div class="app-controls">
            <button class="action-btn lang-btn" data-lang="en" onclick="applyLang('en')">EN</button>
            <button class="action-btn lang-btn" data-lang="pl" onclick="applyLang('pl')">PL</button>
            <label class="toggle-switch-wrap" title="Dark mode">
                <span class="toggle-label">☀</span>
                <label class="toggle-switch">
                    <input type="checkbox" id="darkModeToggle" onchange="toggleTheme()">
                    <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label">☾</span>
            </label>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-title">
            <button class="back-arrow" onclick="history.back()">←</button>
            <span data-i18n="forgot.title">Reset your password</span>
        </div>

        @if (TempData["InfoMessage"] != null)
        {
            <div class="alert alert-info" role="alert">@TempData["InfoMessage"]</div>
        }
        else if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
        }
        else if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger" role="alert">@TempData["ErrorMessage"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label" data-i18n="forgot.email">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="Email" data-i18n="forgot.emailPh" required />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="submitBtn" data-i18n="forgot.btn">Send reset link</button>
        </form>

        <div class="auth-divider" data-i18n="forgot.remember">Remember your password?</div>
        <a asp-page="/Login" class="newAccountBtn" data-i18n="forgot.backLogin">Back to login</a>
    </div>
</div>