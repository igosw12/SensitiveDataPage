@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="wrapper">
    <div class="left">
        Logo - TBD
    </div>

    <div class="right">
        <div class="logInMessage">
            Login into Sensitive Data Manager
        </div> 
        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" placeholder="Email" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control" type="password" placeholder="Password" />
            </div>
            <button type="submit" class="loginBtn">Login</button>
        </form>
        <p> <a asp-page="/ForgotPasword" class="forgotPasswordBtn">Forgot password?</a> </p>
        <div class="joinUsMessage">
            Join us!
        </div>
        <p> <a asp-page="/Register" class="newAccountBtn">Create new account</a> </p>
    </div>

</div> 
