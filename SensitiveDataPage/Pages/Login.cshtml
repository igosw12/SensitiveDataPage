@page
@model SensitiveDataPage.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-page">
    <div class="auth-header">
        <div class="auth-logo">
            <img class="logoImg" src="~/img/logo.png" />
        </div>
        <div class="app-controls">
            <button class="action-btn lang-btn" data-lang="en" onclick="applyLang('en')">EN</button>
            <button class="action-btn lang-btn" data-lang="pl" onclick="applyLang('pl')">PL</button>
            <label class="toggle-switch-wrap" title="Dark mode">
                <span class="toggle-label">☀</span>
                <label class="toggle-switch">
                    <input type="checkbox" id="darkModeToggle" onchange="toggleTheme()">
                    <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label">☾</span>
            </label>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-title" data-i18n="login.title">Login into Sensitive Data Manager</div>

        @if (TempData["InfoMessage"] != null)
        {
            <div class="alert alert-info" role="alert">@TempData["InfoMessage"]</div>
        }
        else if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
        }
        else if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger" role="alert">@TempData["ErrorMessage"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label" data-i18n="login.email">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="Email" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label" data-i18n="login.password">Password</label>
                <input asp-for="Input.Password" class="form-control" type="password" placeholder="Password" />
            </div>
            <button type="submit" class="submitBtn" data-i18n="login.btn">Login</button>
        </form>

        <a class="forgotPasswordBtn" asp-page="/ForgotPassword" data-i18n="login.forgot">Forgot password?</a>

        <div class="auth-divider" data-i18n="login.join">Join us!</div>
        <a asp-page="/Register" class="newAccountBtn" data-i18n="login.register">Create new account</a>
    </div>
</div>
