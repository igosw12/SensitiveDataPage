@page
@model SensitiveDataPage.Pages.PasswordRestartModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="wrapper">
    <div class="left">
        Logo - TBD
    </div>

    <div class="right">
        <div class="CommunicationMessage">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger" role="alert">@TempData["ErrorMessage"]</div>
            }
            else if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
            }
        </div>

        @if (TempData["ErrorMessage"] == null)
        {
            <div class="MainMessage">
                Create a new password
            </div>

            <div asp-validation-summary="All" class="text-danger"></div>

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">New Password</label>
                    <input asp-for="Input.Password" class="form-control" placeholder="New password" required pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$" oninvalid="this.setCustomValidity('Password must have at least 8 characters, a capital letter and a number')" oninput="this.setCustomValidity('')" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.CheckPassword" class="form-label">Confirm Password</label>
                    <input asp-for="Input.CheckPassword" class="form-control" placeholder="Confirm password" oninput="this.setCustomValidity('')" />
                    <span asp-validation-for="Input.CheckPassword" class="text-danger"></span>
                </div>
                <button type="submit" class="submitBtn">Reset Password</button>
            </form>

            <div class="joinUsMessage">
                Back to login?
            </div>
            <p> <a asp-page="/Login" class="newAccountBtn">Go to login</a> </p>
        }
        else
        {
            <div class="joinUsMessage">
                Unable to reset password
            </div>
            <p> <a asp-page="/ForgotPassword" class="newAccountBtn">Request new reset link</a> </p>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

