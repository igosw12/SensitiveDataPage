@page
@model SensitiveDataPage.Pages.PasswordRestartModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-page">
    <div class="auth-header">
        <div class="auth-logo">
            <img class="logoImg" src="~/img/logo.png" />
        </div>
        <div class="app-controls">
            <button class="action-btn lang-btn" data-lang="en" onclick="applyLang('en')">EN</button>
            <button class="action-btn lang-btn" data-lang="pl" onclick="applyLang('pl')">PL</button>
            <label class="toggle-switch-wrap" title="Dark mode">
                <span class="toggle-label">☀</span>
                <label class="toggle-switch">
                    <input type="checkbox" id="darkModeToggle" onchange="toggleTheme()">
                    <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label">☾</span>
            </label>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-title" data-i18n="reset.title">Create a new password</div>

        <div id="formMessage" class="d-none alert" role="alert"></div>

        <form id="resetForm" method="post">
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label" data-i18n="reset.password">New Password</label>
                <input asp-for="Input.Password" class="form-control" placeholder="New password" data-i18n="reset.passwordPh" required
                       pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$"
                       oninvalid="this.setCustomValidity('Password must have at least 8 characters, a capital letter and a number')"
                       oninput="this.setCustomValidity('')" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.CheckPassword" class="form-label" data-i18n="reset.confirmPassword">Confirm Password</label>
                <input asp-for="Input.CheckPassword" class="form-control" placeholder="Confirm password" data-i18n="reset.confirmPh" oninput="this.setCustomValidity('')" />
            </div>
            <button type="submit" class="submitBtn" data-i18n="reset.btn">Reset Password</button>
        </form>

        <div class="auth-divider" data-i18n="reset.backQ">Back to login?</div>
        <a asp-page="/Login" class="newAccountBtn" data-i18n="reset.backLogin">Go to login</a>
    </div>
</div>

@section Scripts {
    <script src="~/js/passwordRestart.js"></script>
}

