@page
@model SensitiveDataPage.Pages.RegisterModel
@{
    ViewData["Title"] = "Register";
}
@inject IConfiguration configuration
@{
    var siteKey = configuration["reCaptchaSettings:SiteKey"];
}

<div class="auth-page">
    <div class="auth-header">
        <div class="auth-logo">
            <img class="logoImg" src="~/img/logo.png" />
        </div>
        <div class="app-controls">
            <button class="action-btn lang-btn" data-lang="en" onclick="applyLang('en')">EN</button>
            <button class="action-btn lang-btn" data-lang="pl" onclick="applyLang('pl')">PL</button>
            <label class="toggle-switch-wrap" title="Dark mode">
                <span class="toggle-label">☀</span>
                <label class="toggle-switch">
                    <input type="checkbox" id="darkModeToggle" onchange="toggleTheme()">
                    <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label">☾</span>
            </label>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-title">
            <button class="back-arrow" onclick="history.back()">←</button>
            <span data-i18n="reg.title">Create a new account and protect your sensitive data</span>
        </div>

        <div id="formMessage" class="d-none alert" role="alert"></div>

        <form id="registerForm" method="post">
            <input type="hidden" id="recaptchaTokenInputId" asp-for="RecaptchaToken" />
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label" data-i18n="reg.email">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="Email" data-i18n="reg.emailPh" required />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label" data-i18n="reg.password">Password</label>
                <input asp-for="Input.Password" class="form-control" placeholder="Password" data-i18n="reg.passwordPh" required
                       pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$"
                       oninvalid="this.setCustomValidity('Password must have at least 8 characters, a capital letter and a number')"
                       oninput="this.setCustomValidity('')" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.CheckPassword" class="form-label" data-i18n="reg.confirmPassword">Confirm password</label>
                <input asp-for="Input.CheckPassword" class="form-control" placeholder="Confirm password" data-i18n="reg.confirmPh" oninput="this.setCustomValidity('')" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.DateOfBirth" class="form-label" data-i18n="reg.birthday">Birthday</label>
                <input asp-for="Input.DateOfBirth" class="form-control" type="date" required />
            </div>
            <div class="mb-3">
                <div id="html_element" data-sitekey="@siteKey"></div>
            </div>
            <button type="submit" class="submitBtn" data-i18n="reg.btn">Register</button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/register.js"></script>
    <script src="https://www.google.com/recaptcha/api.js?onload=onloadCallback&render=explicit" async defer></script>
}
